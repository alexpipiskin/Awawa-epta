{
  "name": "Xray-Codespace",
  "image": "://microsoft.com",
  "customizations": {
    "codespaces": {
      "openFiles": ["setup.sh"]
    }
  },
  "postCreateCommand": "chmod +x setup.sh && ./setup.sh",
  "portsAttributes": {
    "8080": {
      "label": "Xray-Server",
      "onAutoForward": "ignore",
      "visibility": "public"
    }
  },
  "forwardPorts": [8080]
}
